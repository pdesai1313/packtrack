# ── Database (Supabase) ───────────────────────────────────────────────────────
# Transaction pooler — used by the app at runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler — used by Prisma for migrations (db push)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-random-64-char-hex
JWT_REFRESH_SECRET=replace-with-another-random-64-char-hex
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank in dev — emails are logged to the console instead
# Get free key at resend.com (3,000 emails/month free)
RESEND_API_KEY=
EMAIL_FROM=PackTrack <noreply@packtrack.app>
